# Casa Granum — copie para .env e preencha. Nunca versione o .env.

# Quando o Firebird roda no mesmo host (Windows) e não há Docker Desktop,
# use host.docker.internal — o compose já injeta host-gateway no backend.
FB_HOST=192.168.0.10
FB_PORT=3050
FB_DATABASE=C:\caminho\para\PDV.FDB
FB_USER=usuario_somente_leitura
FB_PASSWORD=
FB_CHARSET=ISO8859_1

# Vazio desativa os alertas. Token: @BotFather. Chat ID: getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM da recomendação. Primário + fallback opcional (usado se o primário falhar).
# Valores: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_FALLBACK=

# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Sincronização em tempo real:
# - monitor de estoque (alertas Telegram + lista de reabastecimento)
# - refresh do catálogo da IA (produtos novos no Nutify visíveis em até N segundos)
MONITOR_INTERVAL_MINUTES=5
CATALOG_REFRESH_SECONDS=60
STOCK_ALERT_FACTOR=1.1
STOCK_RESTORE_FACTOR=1.5

CACHE_TTL_HOURS=24

# Quantos snapshots do SQLite manter (rotação automática a cada 24h).
BACKUP_RETENTION=7

# Porta exposta do frontend no host. Se 8080 conflitar, troque livremente.
FRONTEND_PORT=8080

# CORS do backend. Tráfego do browser passa pelo proxy do frontend (same-origin);
# manter aqui só pra acesso direto ao backend em dev/debug.
CORS_ORIGINS=http://localhost:8080

# Cloudflare Tunnel (opcional). Zero Trust → Networks → Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=
